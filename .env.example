# Copy to .env and fill in. .env is gitignored.

# GitHub fine-grained PAT (repo Adoucett/homepage; Contents R/W, Metadata R)
GITHUB_TOKEN=

# Vercel account token (vercel.com > Account Settings > Tokens)
VERCEL_TOKEN=

# Strava app credentials (strava.com/settings/api; callback domain: localhost)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Produced by `npm run strava:auth`
STRAVA_REFRESH_TOKEN=

# Optional: only if keeping Mapbox instead of MapLibre
MAPBOX_TOKEN=
